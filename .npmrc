# @sythir/config-merger is published to GitHub Packages. In the standalone
# hydra-agent repo (no pnpm workspace) this is how pnpm resolves it. In the
# monorepo, link-workspace-packages=true resolves it to packages/config-merger
# before any registry hit, so NODE_AUTH_TOKEN is not needed there.
@sythir:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
